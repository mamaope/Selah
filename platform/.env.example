# ── HOST PORTS ───────────────────────────────────────────────────────────────
# What the server EXPOSES to the outside. Change these if 8080/3000 are taken
# by other projects. The CONTAINER-internal ports never change — nginx still
# listens on 8080 and dials the API on 3000 inside the Docker network.
WEB_PORT=8081
API_PORT=3007

# ── BUILD ────────────────────────────────────────────────────────────────────
# The tests run INSIDE the image build — a wrong Ugandan tax number will not
# build. Leave this true. Set false ONLY for a throwaway dev image when you are
# iterating on the UI and do not want to wait for the full suite each rebuild.
RUN_TESTS=true

# ══════════════════════════════════════════════════════════════════════════════
# SELAH — copy this to .env and fill it in.
#
#   cd platform
#   cp .env.example .env
#   npm run preflight        ← run this BEFORE docker. It will tell you what is wrong.
#   docker compose up --build
#
# .env is gitignored and must stay that way. Never commit a key.
# ══════════════════════════════════════════════════════════════════════════════

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Encryption. Generate each with:  openssl rand -hex 32 ─────────────────────
#
# 🔴 PASTE ONLY THE 64 HEX CHARACTERS. Do not leave a comment on the same line.
#    Two keys, and they MUST be different — the point of the blind index is that
#    compromising one does not compromise the other.
#
SELAH_ENCRYPTION_KEY=
SELAH_INDEX_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# 🔴🔴 STOP. DO NOT FILL IN ANYTHING BELOW THIS LINE.
#
# These four variables are not configuration. They are a LEGAL DECLARATION that
# Selah Solutions Ltd is registered with Uganda's Personal Data Protection Office.
#
# While they are EMPTY, every endpoint that would store a payslip, a TIN, a phone
# number or an invoice returns HTTP 451 — Unavailable For Legal Reasons.
#
# THAT IS NOT AN ERROR TO MAKE GO AWAY. It is the software refusing to break the
# law on your behalf.
#
# Uganda's Data Protection and Privacy Act s.9(1): financial data is SPECIAL
# PERSONAL DATA. Processing it is PROHIBITED BY DEFAULT.
#
#     On 10 July 2025, a digital lender's DIRECTOR was PERSONALLY CONVICTED for
#     failing to register with the PDPO.
#
#     Not the company. THE DIRECTOR.
#
# Filling these in with placeholder values does not make you compliant. It makes
# you compliant-LOOKING — and it removes the one thing standing between you and a
# courtroom: the fact that the software would not let you.
#
# 🔑 THE ONLY TIME YOU TOUCH THESE IS WHEN THE CERTIFICATE IS PHYSICALLY IN YOUR
#    HAND. Then set all four, with the real values, and `npm run preflight` will
#    tell you whether it believes you.
#
# The calculators work regardless. They have never stored anything and never will.
# ══════════════════════════════════════════════════════════════════════════════

PDPO_REGISTRATION_NUMBER=
PDPO_REGISTERED_ON=
DPO_NAME=
DPO_EMAIL=

# ── SMS. Until this is set, production auth REFUSES rather than pretending. ────
SMS_PROVIDER_URL=

# ── EMAIL ────────────────────────────────────────────────────────────────────
# Without these THREE, "forgot password" and email confirmation return an honest
# 503. We will not tell a person to check an inbox for a message nothing sent.
# Any provider with a JSON API works — this is Resend's shape.
MAIL_API_URL=https://api.resend.com/emails
MAIL_API_KEY=
MAIL_FROM=Selah <no-reply@yourdomain.ug>

# The origin used to build the links inside those emails.
PUBLIC_BASE_URL=http://localhost:8080

# ── A SEEDED ADMIN LOGIN (optional, for getting started) ─────────────────────
# Fill these in to create a ready-to-use, ALREADY-VERIFIED account at first
# boot — no registration, no email confirmation. Sign in on the individuals
# page. REMOVE them once the account exists; the login persists without them.
# 'admin' grants no special powers today — it is a verified login, flagged.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_KIND=individual
